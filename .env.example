# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=brAIn.md
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local vault storage
VAULT_ROOT=./vaults

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vault_chunks
QDRANT_VECTOR_SIZE=2048
QDRANT_TIMEOUT_SECONDS=30

# Jasper embedder
JASPER_EMBEDDER_URL=http://localhost:8001
JASPER_MODEL_NAME=infgrad/Jasper-Token-Compression-600M
JASPER_EMBEDDER_TIMEOUT_SECONDS=60
JASPER_MAX_LENGTH=1024

# App
NEXT_PUBLIC_APP_NAME=brAIn.md
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth / MCP
USER_AUTH_SECRET=replace-with-a-long-random-secret
USER_AUTH_STORE_PATH=./.auth/users.json
USER_SESSION_COOKIE=brain_session
USER_SESSION_TTL_SECONDS=2592000
MCP_JWT_SECRET=replace-with-a-long-random-secret
MCP_JWT_ISSUER=brAIn-mcp
MCP_JWT_AUDIENCE=brAIn-mcp
MCP_JWT_REVOCATION_PATH=./vaults/.mcp-jwt-revocations.json
MCP_USAGE_LOG_PATH=./vaults/.mcp-jwt-usage.jsonl
MCP_RATE_LIMIT_PER_HOUR=60

# Realtime / tunnels
NGROK_URL=https://your-ngrok-url.ngrok-free.app
VERCEL_URL=https://your-vercel-deployment.vercel.app
