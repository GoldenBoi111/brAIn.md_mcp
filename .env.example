################################################################################
# ENVIRONMENT CONFIGURATION FOR BRAIN.MD MCP SERVER
# 
# This file configures the brAIn.md system: a local-first vault with semantic
# search, folder-level locking, and MCP (Model Context Protocol) support.
#
# For Docker Compose: Use this file directly with `docker-compose up`
# For local dev: Copy to .env and adjust paths as needed (e.g., VAULT_ROOT)
################################################################################

# ============================================================================
# APPLICATION
# ============================================================================

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=brAIn.md
# Set this to the public URL that ChatGPT/Claude will reach, for example:
# NEXT_PUBLIC_APP_URL=https://your-tunnel.trycloudflare.com
NEXT_PUBLIC_APP_URL=

# ============================================================================
# VAULT STORAGE
# ============================================================================
# Local filesystem root for all user vaults.
# In Docker, this is /app/vaults (see docker-compose.yml volumes).
# In local development, adjust to ./vaults or an absolute path.

VAULT_ROOT=./vaults

# ============================================================================
# QDRANT VECTOR DATABASE
# ============================================================================
# Qdrant stores embeddings and allows semantic search over vault content.
# In Docker: use http://qdrant:6333 (service name)
# In local dev: use http://localhost:6333

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vault_chunks
QDRANT_VECTOR_SIZE=2048
QDRANT_TIMEOUT_SECONDS=30

# ============================================================================
# JASPER EMBEDDING MODEL
# ============================================================================
# Jasper Token Compression model converts text to 2048-dimensional vectors.
# In Docker: use http://jasper-embedder:8001 (service name)
# In local dev: use http://localhost:8001 if running the service separately.

JASPER_EMBEDDER_URL=http://localhost:8001
JASPER_MODEL_NAME=infgrad/Jasper-Token-Compression-600M
JASPER_EMBEDDER_TIMEOUT_SECONDS=60
JASPER_MAX_LENGTH=1024

# ============================================================================
# USER AUTHENTICATION
# ============================================================================
# Session-based auth for the web UI and protected REST endpoints.

# IMPORTANT: Generate a strong secret for production.
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
USER_AUTH_SECRET=replace-with-a-long-random-secret

USER_AUTH_STORE_PATH=./.auth/users.json
USER_SESSION_COOKIE=brain_session
USER_SESSION_TTL_SECONDS=2592000

# ============================================================================
# MCP (MODEL CONTEXT PROTOCOL) TOKEN CONFIGURATION
# ============================================================================
# MCP tokens allow LLM clients to access the vault through JSON-RPC.
# These are separate from session auth; the user creates a token in the UI,
# then configures the LLM client to use it.

# IMPORTANT: Generate strong secrets for production.
MCP_JWT_SECRET=replace-with-a-long-random-secret
MCP_JWT_ISSUER=brAIn-mcp
MCP_JWT_AUDIENCE=brAIn-mcp

# Paths for JWT revocation tracking and usage logging.
# In Docker, these are /app/vaults/.* (inside vault_storage volume).
MCP_JWT_REVOCATION_PATH=./vaults/.mcp-jwt-revocations.json
MCP_USAGE_LOG_PATH=./vaults/.mcp-jwt-usage.jsonl

# ============================================================================
# CLAUDE WEB OAUTH BRIDGE
# ============================================================================
# Claude web can register as an OAuth client against these bridge routes.
# The bridge exchanges the auth code for the same signed MCP JWT used by /mcp.

CLAUDE_OAUTH_STORE_PATH=./.auth/claude-oauth.json
CLAUDE_OAUTH_CODE_TTL_SECONDS=600
CLAUDE_OAUTH_ACCESS_TTL_DAYS=365
CLAUDE_OAUTH_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
CLAUDE_OAUTH_CLIENT_SECRET=replace-with-a-long-random-secret

# Rate limiting: max requests per MCP token per hour.
MCP_RATE_LIMIT_PER_HOUR=60

# ============================================================================
# DEPLOYMENT (Optional)
# ============================================================================
# Uncomment and configure if deploying to Vercel or using ngrok tunneling.

# NGROK_URL=https://your-ngrok-url.ngrok-free.app
# VERCEL_URL=https://your-vercel-deployment.vercel.app
